{
  "name": "pi-vitals",
  "version": "1.2.2",
  "description": "A customizable powerline-style footer for pi",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc --project tsconfig.json",
    "benchmark": "node --import tsx benchmark.ts"
  },
  "files": [
    "*.ts",
    "*.json",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcowger/pi-vitals.git"
  },
  "bugs": {
    "url": "https://github.com/mcowger/pi-vitals/issues"
  },
  "homepage": "https://github.com/mcowger/pi-vitals#readme",
  "keywords": [
    "pi",
    "extension",
    "footer",
    "powerline",
    "pi-package",
    "pi-coding-agent"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "author": "Matt Cowger",
  "license": "MIT",
  "devDependencies": {
    "@earendil-works/pi-ai": "0.80.10",
    "@earendil-works/pi-coding-agent": "0.80.10",
    "@earendil-works/pi-tui": "0.80.10",
    "@types/node": "24.13.3",
    "tsx": "4.23.1",
    "typescript": "5.9.3"
  }
}
